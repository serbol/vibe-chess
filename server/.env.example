# Port the server binds to. Render and most PaaS providers inject PORT — leave unset
# in production unless your host doesn't.
PORT=3000

# Comma-free single origin allowed by CORS and Socket.IO. Use the deployed
# frontend URL in production (e.g. https://chess-game.pages.dev). In local dev,
# either omit (defaults to *) or set http://localhost:5173.
CLIENT_ORIGIN=http://localhost:5173
